{
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));const c=d.tool_input.command||'';const p=[/rm -rf/,/git push.*--force/,/git reset --hard/,/git clean -f/,/npm publish/,/dd if=/,/mkfs/,/curl.*\\|.*sh/,/wget.*\\|.*sh/];const m=p.find(r=>r.test(c));if(m){process.stderr.write('Blocked: '+c);process.exit(2)}\"",
            "statusMessage": "Checking for dangerous commands..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));const c=d.tool_input.command||'';if(/git commit/.test(c)){const r=require('child_process').spawnSync('npm',['run','build'],{stdio:'inherit',shell:true});if(r.status!==0){process.stderr.write('Build failed -- commit blocked\\n');process.exit(2)}}\"",
            "statusMessage": "Running build check before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$raw = [Console]::In.ReadToEnd(); $data = $raw | ConvertFrom-Json; $f = $data.tool_input.file_path; if ($f) { npx prettier --write $f --ignore-unknown 2>$null }; exit 0",
            "statusMessage": "Formatting with Prettier..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(biome:*)",
      "Bash(bun:*)",
      "Bash(cypress:*)",
      "Bash(eslint:*)",
      "Bash(gh auth status:*)",
      "Bash(gh browse:*)",
      "Bash(gh gist create:*)",
      "Bash(gh gist edit:*)",
      "Bash(gh gist list:*)",
      "Bash(gh gist view:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue reopen:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh label:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr close:*)",
